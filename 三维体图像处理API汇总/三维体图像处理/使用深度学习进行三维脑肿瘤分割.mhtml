blockMetrics.ImageNumber =3D bstruct.ImageNumber;
blockInfo.Start =3D bstruct.Start;
blockInfo.End =3D bstruct.End;
blockMetrics.BlockInfo =3D blockInfo;

<span style=3D"color:#0000FF">end</span></pre></div></div></div><h3 class=
