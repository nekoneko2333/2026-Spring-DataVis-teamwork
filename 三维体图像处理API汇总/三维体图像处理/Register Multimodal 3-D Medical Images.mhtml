py" id=3D"copy_popover_01"></span> Get <span class=3D"caret" id=3D"copy_pop=
over_01"></span></span></button><ul class=3D"dropdown-menu dropdown-menu-ri=
ght copy_code"><li class=3D"copy_code_block"><button id=3D"copyBlock01"><sp=
an class=3D"icon-copy"></span> Copy Code Block</button></li><li role=3D"sep=
arator" aria-hidden=3D"true" class=3D"divider"></li><li class=3D"copy_code_=
openexample"><p><span class=3D"icon-webinar"></span> Copy openExample Comma=
nd<br><small>Paste command in MATLAB to download and open example files</sm=
all></p><div role=3D"presentation" class=3D"input-group"><input type=3D"tex=
t" class=3D"form-control" readonly=3D"" value=3D"openExample('images/Volume=
RegistrationExample')"><span class=3D"input-group-btn"><button class=3D"btn=
 btn_color_blue" type=3D"button" id=3D"copyCommand01"><span class=3D"icon-c=
opy"><span class=3D"sr-only">Copy</span></span></button></span></div></li><=
/ul></div><pre>fixedVolume =3D multibandread(<span style=3D"color:#A020F0">=
"rirePatient007MRT1.bin"</span>, <span style=3D"color:#0000FF">...</span>
    [fixedHeader.Rows fixedHeader.Columns fixedHeader.Slices], <span style=
=3D"color:#0000FF">...</span>
    <span style=3D"color:#A020F0">"int16=3D&gt;single"</span>,0,<span style=
=3D"color:#A020F0">"bsq"</span>,<span style=3D"color:#A020F0">"ieee-be"</sp=
an>);
                       =20
movingVolume =3D multibandread(<span style=3D"color:#A020F0">"rirePatient00=
7CT.bin"</span>, <span style=3D"color:#0000FF">...</span>
    [movingHeader.Rows movingHeader.Columns movingHeader.Slices], <span sty=
