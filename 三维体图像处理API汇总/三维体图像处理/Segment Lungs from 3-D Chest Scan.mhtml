s=3D"sr-only">Copy</span></span></button></span></div></li></ul></div><pre>=
mask =3D false(size(V));
mask(:,:,160) =3D maskedImageXY;
mask(256,:,:) =3D mask(256,:,:)|reshape(maskedImageXZ,[1,512,318]);</pre></=
div></div></div><p>Using this 3-D seed mask, segment the lungs in the 3-D v=
olume using the active contour method. This operation can take a few minute=
s. To get a quality segmentation, use <a href=3D"https://ww2.mathworks.cn/h=
elp/releases/R2023b/images/ref/histeq.html" data-docid=3D"images_ref#bvhelu=
e-1" class=3D"a"><code class=3D"olink">histeq</code></a> to spread voxel va=
lues over the available range.</p><div class=3D"code_responsive -has_code_c=
opy"><div class=3D"programlisting"><div class=3D"codeinput"><div class=3D"b=
tn-group code_actions"> <button type=3D"button" class=3D"btn btn-default dr=
opdown-toggle" data-toggle=3D"dropdown" aria-haspopup=3D"true" aria-expande=
d=3D"false"> <span class=3D"copy_code_popover_target" id=3D"copy_popover_01=
0"><span class=3D"icon-copy" id=3D"copy_popover_010"></span> Get <span clas=
s=3D"caret" id=3D"copy_popover_010"></span></span></button><ul class=3D"dro=
pdown-menu dropdown-menu-right copy_code"><li class=3D"copy_code_block"><bu=
tton id=3D"copyBlock010"><span class=3D"icon-copy"></span> Copy Code Block<=
/button></li><li role=3D"separator" aria-hidden=3D"true" class=3D"divider">=
</li><li class=3D"copy_code_openexample"><p><span class=3D"icon-webinar"></=
span> Copy openExample Command<br><small>Paste command in MATLAB to downloa=
d and open example files</small></p><div role=3D"presentation" class=3D"inp=
ut-group"><input type=3D"text" class=3D"form-control" readonly=3D"" value=
=3D"openExample('images/SegmentLungsFrom3DChestScanExample')"><span class=
=3D"input-group-btn"><button class=3D"btn btn_color_blue" type=3D"button" i=
d=3D"copyCommand010"><span class=3D"icon-copy"><span class=3D"sr-only">Copy=
</span></span></button></span></div></li></ul></div><pre>V =3D histeq(V);

BW =3D activecontour(V,mask,100,<span style=3D"color:#A020F0">"Chan-Vese"</=
span>);

segmentedImage =3D V.*single(BW);</pre></div></div></div><p>View the segmen=
ted lungs in the <strong class=3D"emphasis bold">Volume Viewer</strong> app=
.</p><div class=3D"code_responsive -has_code_copy"><div class=3D"programlis=
ting"><div class=3D"codeinput"><div class=3D"btn-group code_actions"> <butt=
on type=3D"button" class=3D"btn btn-default dropdown-toggle" data-toggle=3D=
"dropdown" aria-haspopup=3D"true" aria-expanded=3D"false"> <span class=3D"c=
opy_code_popover_target" id=3D"copy_popover_011"><span class=3D"icon-copy" =
id=3D"copy_popover_011"></span> Get <span class=3D"caret" id=3D"copy_popove=
r_011"></span></span></button><ul class=3D"dropdown-menu dropdown-menu-righ=
t copy_code"><li class=3D"copy_code_block"><button id=3D"copyBlock011"><spa=
n class=3D"icon-copy"></span> Copy Code Block</button></li><li role=3D"sepa=
