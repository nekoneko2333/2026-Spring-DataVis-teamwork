i></ul></div><pre>spacingx =3D 0.76;
spacingy =3D 0.76;
spacingz =3D 1.26*1e-6;
unitvol =3D spacingx*spacingy*spacingz;

volLungs1 =3D volLungsPixels.Volume(1)*unitvol;
